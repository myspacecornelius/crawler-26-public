# ──────────────────────────────────────────────────
#  LeadFactory — Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All values shown are defaults (safe for local development).

# ── General ────────────────────────────────────
DEBUG=false

# ── Database ───────────────────────────────────
# SQLite (default for development):
DATABASE_URL=sqlite+aiosqlite:///./data/leadfactory.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/leadfactory
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ── JWT / Auth ─────────────────────────────────
# IMPORTANT: Set a strong, unique secret in production!
# If not set, a random key is generated on each restart (invalidating tokens).
LEADFACTORY_SECRET_KEY=change-me-to-a-random-secret

# ── Rate Limiting ──────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_DEFAULT=60/minute

# ── CORS ───────────────────────────────────────
# Comma-separated list of allowed origins.
# Add your staging/production frontend URLs here.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ── Stripe Billing ─────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_CREDITS_1K=
STRIPE_PRICE_CREDITS_5K=
STRIPE_PRICE_CREDITS_10K=

# ── Frontend ───────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Redis / Task Queue ────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Outreach Providers ────────────────────────
INSTANTLY_API_KEY=
SMARTLEAD_API_KEY=

# ── SMTP (for email sending) ──────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
